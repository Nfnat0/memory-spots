    "NSCameraUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use the camera to take landmark photos along your memory route."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶の道順に沿った道しるべ写真を撮影するためにカメラを使用します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwende die Kamera, um Wegpunktfotos entlang deiner Erinnerungsroute aufzunehmen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez l’appareil photo pour prendre des photos repères le long de votre parcours de mémoire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la fotocamera per scattare foto dei punti lungo il tuo percorso di memoria."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa la cámara para tomar fotos de referencia en tu ruta de memoria."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기억 경로를 따라 지점 사진을 촬영하기 위해 카메라를 사용합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने स्मृति मार्ग के पड़ावों की फ़ोटो लेने के लिए कैमरा उपयोग करें।"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show your location on the map and tag photos with geographic coordinates."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "マップ上に現在地を表示し、写真に位置情報を追加するために位置情報を使用します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeige deinen Standort auf der Karte und versieh Fotos mit geografischen Koordinaten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affichez votre position sur la carte et associez des coordonnées géographiques aux photos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Mostra la tua posizione sulla mappa e aggiungi coordinate geografiche alle foto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra tu ubicación en el mapa y etiqueta fotos con coordenadas geográficas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지도에 현재 위치를 표시하고 사진에 지리 좌표를 추가합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैप पर अपना स्थान दिखाने और फ़ोटो में भौगोलिक निर्देशांक जोड़ने के लिए स्थान उपयोग करें।"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose landmark photos from your library to add to your memory route."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶の道順に追加する道しるべ写真をライブラリから選択するために写真ライブラリを使用します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle Wegpunktfotos aus deiner Mediathek aus, um sie deiner Erinnerungsroute hinzuzufügen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez des photos repères dans votre photothèque pour les ajouter à votre parcours de mémoire."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli foto dei punti dalla libreria da aggiungere al tuo percorso di memoria."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige fotos de referencia de tu biblioteca para añadirlas a tu ruta de memoria."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보관함에서 지점 사진을 선택해 기억 경로에 추가합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने स्मृति मार्ग में जोड़ने के लिए लाइब्रेरी से पड़ाव फ़ोटो चुनें।"
          }
        }
      }
    }
  },
  "version": "1.0"
}
