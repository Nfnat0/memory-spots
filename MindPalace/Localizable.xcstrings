    "Use edit mode to rename themes, delete photos, or move photos in the route." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Im Bearbeitungsmodus kannst du Themen umbenennen, Fotos löschen oder Fotos in der Route verschieben."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
