    "You can save photos without a location and add it on the map later." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst Fotos ohne Ort speichern und ihn später auf der Karte hinzufügen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puedes guardar fotos sin ubicación y añadirla después en el mapa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez enregistrer des photos sans lieu et l’ajouter plus tard sur la carte."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आप स्थान के बिना फ़ोटो सहेज सकते हैं और बाद में मैप पर जोड़ सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi salvare foto senza posizione e aggiungerla dopo sulla mappa."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "場所なしでも写真を保存できます。あとから地図で場所を追加できます。"
