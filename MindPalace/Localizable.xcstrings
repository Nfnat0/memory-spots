    "A sample memory set using familiar everyday spaces (My Room, Desk Setup, Local Park).": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "身近な日常生活の場所（自分の部屋、デスク、公園）を使ったサンプルの記憶セット。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Beispielalbum mit vertrauten Alltagsorten (mein Zimmer, Schreibtisch, Park)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un album d’exemple avec des espaces familiers du quotidien (ma chambre, bureau, parc)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un album di esempio con spazi quotidiani familiari (la mia stanza, scrivania, parco)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un álbum de ejemplo con espacios cotidianos familiares (mi habitación, escritorio, parque)."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "익숙한 일상 공간(내 방, 책상, 동네 공원)을 사용하는 샘플 앨범입니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "परिचित रोज़मर्रा की जगहों (मेरा कमरा, डेस्क सेटअप, स्थानीय पार्क) वाला नमूना एल्बम।"
          }
        }
      }
    },
