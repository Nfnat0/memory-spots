    "Photos work best when they show concrete places you can imagine walking through." : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fotos funktionieren am besten, wenn sie konkrete Orte zeigen, durch die du gedanklich gehen kannst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las fotos funcionan mejor cuando muestran lugares concretos que puedes imaginar recorriendo."
