        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ऐसी फ़ोटो सबसे अच्छी होती हैं जिनमें वे ठोस स्थान दिखें जहां आप चलने की कल्पना कर सकें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le foto funzionano meglio quando mostrano luoghi concreti che puoi immaginare di attraversare."
