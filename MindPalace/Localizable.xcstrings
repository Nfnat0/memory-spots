    "Add locations to your photos to see your memory trail on the map.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真に場所を追加すると、思い出すための道しるべがここに並びます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge deinen Fotos Orte hinzu, um deine Erinnerungsroute auf der Karte zu sehen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des lieux à vos photos pour voir votre parcours mémoire sur la carte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi luoghi alle foto per vedere il tuo percorso di memoria sulla mappa."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade ubicaciones a tus fotos para ver tu recorrido de memoria en el mapa."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진에 위치를 추가해 지도에서 기억 경로를 확인하세요."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मैप पर अपनी यादों का मार्ग देखने के लिए फ़ोटो में स्थान जोड़ें।"
          }
        }
      }
    },
    "Add notes to this theme to walk through them in photo order.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このテーマにメモを置くと、写真の道順でたどれます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge diesem Thema Notizen hinzu, um sie in Fotoreihenfolge durchzugehen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez des notes à ce thème pour les parcourir dans l’ordre des photos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi note a questo tema per ripassarle nell’ordine delle foto."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade notas a este tema para recorrerlas en orden de fotos."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 테마에 노트를 추가하면 사진 순서대로 복습할 수 있습니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोटो क्रम में देखने के लिए इस थीम में नोट जोड़ें।"
          }
        }
      }
    },
