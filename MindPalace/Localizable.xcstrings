        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "위치 없이 사진을 저장하고 나중에 지도에서 추가할 수 있습니다."
          }
        }
      }
    },
    "You've placed '%@' in the room. When you visualize walking past that spot in your room, you will naturally trigger the memory of '%@'." : {
      "comment" : "A body text that describes the effect of placing a note in a room. The first argument is the string “”. The second argument is the string “”.",
      "extractionState" : "manual",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du hast '%@' im Raum platziert. Wenn du dir vorstellst, an dieser Stelle vorbeizugehen, wird die Erinnerung an '%@' ausgelöst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Colocaste '%@' en la habitación. Al imaginar que pasas por ese punto, recordarás naturalmente '%@'."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous avez placé '%@' dans la pièce. En imaginant passer devant cet endroit, le souvenir de '%@' reviendra naturellement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपने कमरे में '%@' रखा है। जब आप उस जगह से गुजरने की कल्पना करेंगे, तो '%@' की याद स्वाभाविक रूप से आएगी।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hai posizionato '%@' nella stanza. Quando immagini di passare da quel punto, il ricordo di '%@' si attiverà naturalmente."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "部屋の中に「%1$@」を置きました。その場所を通り過ぎる様子を思い浮かべると、「%2$@」の記憶が自然に呼び起こされます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "방에 '%@'을(를) 놓았습니다. 그 지점을 지나가는 모습을 떠올리면 자연스럽게 '%@'이(가) 기억납니다."
          }
        }
      }
    }
  },
  "version" : "1.1"
