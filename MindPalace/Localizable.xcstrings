    "Albums are routes made from ordered place photos.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アルバムは、順番に並べた場所の写真で作るルートです。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alben sind Routen aus geordneten Ortsfotos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les albums sont des parcours composés de photos de lieux ordonnées."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli album sono percorsi creati con foto di luoghi in ordine."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los álbumes son rutas creadas con fotos de lugares ordenadas."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앨범은 순서대로 정리한 장소 사진으로 만든 경로입니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एल्बम क्रम में रखी गई स्थान फ़ोटो से बने मार्ग हैं।"
          }
        }
      }
    },
    "Use this screen to shape the route and choose what you are memorizing.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "この画面でルートを整え、覚える内容を選びます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf diesem Bildschirm formst du die Route und wählst aus, was du dir merken willst."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez cet écran pour organiser le parcours et choisir ce que vous mémorisez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa questa schermata per costruire il percorso e scegliere cosa memorizzare."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Usa esta pantalla para dar forma a la ruta y elegir qué memorizar."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 화면에서 경로를 다듬고 외울 내용을 선택합니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस स्क्रीन पर मार्ग बनाएं और चुनें कि आप क्या याद कर रहे हैं।"
          }
        }
      }
    },
    "Place notes directly on the photo where you want the memory cue to live.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記憶の手がかりを置きたい写真上の場所に、メモを直接配置します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Platziere Notizen direkt auf dem Foto an der Stelle, an der der Hinweis bleiben soll."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Placez les notes directement sur la photo, à l’endroit où le repère doit rester."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Posiziona le note direttamente sulla foto, nel punto in cui vuoi fissare l’indizio."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Coloca notas directamente en la foto donde quieras dejar la pista de memoria."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기억 단서를 남기고 싶은 사진 위치에 노트를 직접 놓습니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ोटो पर वहीं नोट रखें जहां आप स्मृति संकेत रखना चाहते हैं।"
          }
        }
      }
    },
    "Walk through the route and recall the notes attached to each place.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ルートをたどりながら、各場所に置いたメモを思い出します。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Gehe die Route durch und erinnere dich an die Notizen an jedem Ort."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Parcourez le trajet et rappelez-vous les notes attachées à chaque lieu."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Percorri il tragitto e richiama le note collegate a ogni luogo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recorre la ruta y recuerda las notas asociadas a cada lugar."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경로를 따라가며 각 장소에 붙인 노트를 떠올립니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मार्ग पर चलते हुए हर स्थान से जुड़े नोट याद करें।"
          }
        }
      }
    },
