      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "場所法（記憶の宮殿）は、情報を物理的な場所に関連付ける古代の記憶術です。まずは部屋の中に最初の記憶のしずく（メモ）を置いてみましょう！"
          }
        }
      }
    },
