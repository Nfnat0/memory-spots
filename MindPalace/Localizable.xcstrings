    "Themes let the same photo route hold different things to memorize.": {
      "extractionState": "manual",
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "テーマを使うと、同じ写真ルートに別々の暗記内容を持たせられます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Themen kann dieselbe Fotoroute verschiedene Lerninhalte tragen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les thèmes permettent au même parcours photo de contenir différentes choses à mémoriser."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I temi permettono allo stesso percorso fotografico di contenere elementi diversi da memorizzare."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los temas permiten que la misma ruta de fotos guarde distintas cosas para memorizar."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "테마를 사용하면 같은 사진 경로에 서로 다른 암기 내용을 담을 수 있습니다."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "थीम से उसी फ़ोटो मार्ग में याद करने की अलग-अलग चीज़ें रखी जा सकती हैं।"
          }
        }
      }
    },
